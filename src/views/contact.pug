doctype html 
html(lang='es')
  head 
    include partials/head
body(class='bg-dominant text-secundary')
  include partials/header
  div(class='lg:w-[50%] max-lg:px-[2.5%] mx-auto') 
    h3(class='text-paragraph mb-16') Nuevos proyectos o colaboraciones, estoy abierto a ellos. No dudes en contactarme a través del siguiente formulario y medios disponibles.
    h1(class='text-2xl text-secundary font-bold mb-5') Contactamé
    form(action="#" class='flex flex-col gap-8 max-sm:px-2')
      div(class='grid grid-cols-2 gap-8 max-sm:grid-cols-1') 
        input(type="text" placeholder='Nombre' class='bg-terciary py-3 px-4 rounded-lg')
        input(type="text" placeholder='Apellido' class='bg-terciary py-3 px-4 rounded-lg')
        input(type="text" placeholder='Asunto' class='bg-terciary py-3 px-4 rounded-lg') 
        input(type="text" placeholder='Correo electronico' class='bg-terciary py-3 px-4 rounded-lg')
      <textarea placeholder="Mensaje" rows="10" class='resize-none bg-terciary py-3 px-4 rounded-lg'></textarea>
 
      input(type="submit" class='self-start py-5 px-10 rounded-lg bg-accent text-terciary cursor-pointer' value="Enviar mensaje")
  include partials/footer