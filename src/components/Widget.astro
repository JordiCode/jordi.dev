---
import MailIcon from "./icons/MailIcon";
---

<div
  class="flex max-w-[984px] w-full text-right mx-auto fixed bottom-16 right-['50%_-_492px']"
>
  <div
    class="cursor-pointer bg-zinc-900 hover:bg-black dark:bg-zinc-200 dark:hover:bg-white absolute right-0 px-5 py-2 rounded-full hover:scale-105 transition-all"
  >
    <span class="flex gap-3 items-center">
      <p class="text-white dark:text-black text-sm">Contact Me</p>
      <MailIcon classes="size-5" gClasses="stroke-white dark:stroke-black" />
    </span>
  </div>
</div>
