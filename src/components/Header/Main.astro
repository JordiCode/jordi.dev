---
import Link from "../ui/Link.astro";
import SunMoon from "./SunMoon";

const navLinks = [
  {
    url: "/",
    text: "Portfolio",
  },
  {
    url: "/blog",
    text: "Blog",
  },
];
---

<header class="py-5 flex justify-between">
  <nav class="w-max py-1">
    <ul class="flex gap-5">
      {
        navLinks.map(({ url, text }) => (
          <li class="text-sm text-zinc-600 hover:text-zinc-900  dark:text-zinc-400 dark:hover:text-zinc-50 transition-colors">
            <Link href={url}>{text}</Link>
          </li>
        ))
      }
    </ul>
  </nav>
  <SunMoon client:load />
</header>
