---
const classes =
  "!border-zinc-500 focus:!border-black dark:focus:!border-white col-span-1 row-span-1 max-sm:col-span-2";
---

<form
  action="#"
  class="grid grid-cols-2 grid-rows-5 max-sm:grid-rows-7 gap-4 text-xs mb-4 w-full"
  id="form"
>
  <input
    type="text"
    name="firstName"
    class={classes}
    placeholder="First Name*"
    required
  />
  <input
    type="text"
    name="lastName"
    class={classes}
    placeholder="Last Name*"
    required
  />
  <input
    type="email"
    name="email"
    class={classes}
    placeholder="Email*"
    required
  />
  <input
    type="text"
    name="subject"
    class={classes}
    placeholder="Subject*"
    required
  />
  <textarea
    name="message"
    class="!border-zinc-500! focus:border-black! col-span-2 row-span-2 dark:focus:border-white!"
    placeholder="Message*"
    required></textarea>
  <div class="cf-turnstile" data-sitekey="0x4AAAAAACDH8R9gLV4uLnb0"></div>
  <input
    value="Send"
    type="submit"
    class="border-zinc-500! hover:border-black! col-span-2 row-span-2 cursor-pointer dark:hover:border-white!"
  />
</form>
<div class="hidden" id="loader"></div>
<div class="hidden" id="warning"></div>

<style>
  input,
  textarea {
    border: 1px;
    border-style: solid;
    padding: 1rem 0.5rem;
    border-radius: 0.375rem;
    transition: border-color 0.2s linear;
  }

  #loader {
    width: 25px;
    margin: mx-auto;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 3px solid rgb(225, 225, 225);
    border-right-color: #1f1f1f;
    animation: l2 0.5s infinite linear;
  }

  @keyframes l2 {
    to {
      transform: rotate(1turn);
    }
  }
</style>

<script>
  var clearWarning = function () {
    setTimeout(() => {
      warning.style.display = "none";
    }, 10000);
  };

  var form = document.getElementById("form") as HTMLFormElement;
  const loader = document.getElementById("loader") as HTMLDivElement;
  const warning = document.getElementById("warning") as HTMLDivElement;

  form.addEventListener("submit", async function (e) {
    loader.style.display = "block";
    console.log(loader);
    e.preventDefault();

    var data = Object.fromEntries(new FormData(e.target as HTMLFormElement));
    console.log(JSON.stringify(data));
    const response = await fetch(
      "https://2w9jbd639a.execute-api.us-east-1.amazonaws.com",
      {
        method: "post",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      }
    );

    setTimeout(() => {
      if (response.ok) {
        loader.style.display = "none";
        warning.style.display = "block";
        warning.style.color = "#36b460";
        warning.textContent = "The message has been sent correctly";
        clearWarning();
        this.reset();
      } else {
        loader.style.display = "none";
        warning.style.display = "block";
        warning.style.color = "#b43636";
        warning.textContent = "There was an error sending the message";
        clearWarning();
      }
    }, 5000);
  });
</script>
