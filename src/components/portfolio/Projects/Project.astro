---
import EyeIcon from "../icons/EyeIcon.astro";
import GithubIcon from "../icons/Stack/GithubIcon.astro";
import AstroIcon from "../icons/Stack/AstroIcon.astro";
import FigmaIcon from "../icons/Stack/FigmaIcon.astro";
import JavaScriptIcon from "../icons/Stack/JavaScriptIcon.astro";
import TailWindCssIcon from "../icons/Stack/TailWindCssIcon.astro";
import LoadingIcon from "../icons/LoadingIcon.astro";
const linkClasses =
  "items-center justify-center gap-2 px-2 py-2 space-x-2 text-xs text-black  transition  hover:bg-blue-200   border-zinc-700 text-md  hover:border-gray-900 group max-w-fit rounded-md focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:bg-black";

interface Props {
  status: string;
  srcImg: string;
  title: string;
  description: string;
  linkPreview: string | undefined;
  linkCode: string | undefined;
  tools: string[];
}

const iconMap: any = {
  astro: AstroIcon,
  tailwindcss: TailWindCssIcon,
  javascript: JavaScriptIcon,
  figma: FigmaIcon,
};

const statusColor: any = {
  production: "bg-green-700",
  building: "bg-yellow-700",
};

const { status, srcImg, title, description, linkPreview, linkCode, tools } =
  Astro.props;
---

<div class="project">
  <span class="loadingMsg flex gap-4 mt-24">
    <LoadingIcon />
    <p class="text-sm font-light">loading</p>
  </span>
  <div class={"flex flex-col max-lg:grid invisible "}>
    <img
      alt={"Image not found"}
      data-src={srcImg}
      class="projectImg border-zinc-600
    max-lg:max-w-full border rounded-lg"
    />

    <div class="pt-4">
      <div class={"flex flex-col items-start gap-2 mb-5"}>
        <h2 class="text-2xl">{title}</h2>
        <span
          class={`text-[0.6rem] ${statusColor[status]} text-white  px-4 rounded-md capitalize`}
          title={"Status"}
        >
          {status}
        </span>
      </div>
      <p class="text-xs text-zinc-600 dark:text-zinc-300 mb-4">
        {description}
      </p>

      <a
        href={linkCode}
        target={"_blank"}
        role="link"
        class={`${linkCode == undefined ? "hidden" : "inline-flex"} ${linkClasses}`}
      >
        <GithubIcon />
        Code
      </a>

      <a
        href={linkPreview}
        target={"_blank"}
        role="link"
        class={`${linkPreview == undefined ? "hidden" : "inline-flex"} ${linkClasses}`}
      >
        <EyeIcon />
        Preview
      </a>
    </div>
  </div>
</div>
