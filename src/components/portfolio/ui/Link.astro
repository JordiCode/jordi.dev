---
import BlogIcon from "../icons/BlogIcon.astro";
import HouseIcon from "../icons/HouseIcon.astro";

interface Props {
  currentPath: string;
  iconName?: string;
  href: string;
  className?: string;
}

const { currentPath, iconName, href, className } = Astro.props;

const icons = {
  house: HouseIcon,
  blog: BlogIcon,
};

const SelectedIcon = iconName ? icons[iconName as keyof typeof icons] : null;

const isSamePage = currentPath == href;
---

<a
  href={href}
  class={`${className} ${iconName ? "flex gap-2" : ""}  ${isSamePage ? "pointer-events-none" : ""}`}
>
  {iconName && SelectedIcon ? <SelectedIcon /> : false}
  <slot />
</a>
