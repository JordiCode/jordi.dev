---
import Twitter from "./icons/Twitter.astro";
import GitHub from "./icons/GitHub.astro"
import Linkedin from "./icons/Linkedin.astro"
const { sizeIcon } = Astro.props
const classNameIcon = `hover:text-white w-${sizeIcon} h-${sizeIcon}`
---

<div class:list={['flex gap-5']}>
    <a href="#">
        <Twitter className={classNameIcon}/>
    </a>
    <a href="#">
        <Linkedin className={classNameIcon}/>
    </a>
    <a href="#">
        <GitHub className={classNameIcon}/>
    </a>
</div>